{
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git tag *)",
      "Bash(git config *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr status *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh api *)",
      "Bash(npx *)",
      "Bash(nx *)",
      "Bash(npm *)",
      "Bash(timeout *)",
      "Bash(for *)",
      "Bash(find *)",
      "Bash(node *)",
      "Bash(npx nx *)",
      "Read(//tmp/**)",
      "Bash(grep *)",
      "Bash(sed *)",
      "WebFetch(*)",
      "Bash(python3 *)",
      "Bash(node -e ' *)",
      "Bash(gh secret *)",
      "Bash(xargs -I{} echo {})"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-dangerous.sh",
            "if": "Bash(git push *)|Bash(git reset *)|Bash(rm *)",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/pre-push-reminder.sh",
            "if": "Bash(git push *)",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/update-versions-on-package-change.sh",
            "if": "Write(*package.json)",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
