{
  "env": {
    "CLAUDE_CODE_ENABLE_AUTO_MODE": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git tag *)",
      "Bash(git config *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr status *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh api *)",
      "Bash(npx *)",
      "Bash(nx *)",
      "Bash(npm *)",
      "Bash(timeout *)",
      "Bash(for *)",
      "Bash(find *)",
      "Bash(node *)",
      "Bash(npx nx *)",
      "Read(//tmp/**)",
      "Bash(grep *)",
      "Bash(sed *)",
      "WebFetch(*)",
      "Bash(python3 *)",
      "Bash(node -e ' *)",
      "Bash(git check-ignore *)",
      "Bash(git worktree *)",
      "Bash(git commit -m ' *)",
      "Bash(echo \"exit: $?\")",
      "Bash(git -C /home/mario/repos/my-personal-project log --all --oneline -- package-lock.json)",
      "Bash(curl -s http://localhost:6097/iframe.html -o /tmp/claude-1000/-home-mario-repos-my-personal-project/86bf06d3-25de-4ab2-ad8a-67244160a273/scratchpad/iframe.html)",
      "Bash(kill %1)",
      "Bash(wait)",
      "Edit(/.claude/**)",
      "WebSearch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-dangerous.sh",
            "if": "Bash(git push *)|Bash(git reset *)|Bash(rm *)",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/pre-push-reminder.sh",
            "if": "Bash(git push *)",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/update-versions-on-package-change.sh",
            "if": "Write(*package.json)",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
